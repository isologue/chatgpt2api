# ============================================
# ChatGPT2API 环境变量
# 当前配置：默认使用 sqlite
# 如果切到 postgres：
# 1. 把 STORAGE_BACKEND 改成 postgres
# 2. 把 DATABASE_URL 改成 postgres 连接串
# 3. 把 ENABLE_POSTGRES_STORAGE 改成 1（本地构建时）
# 4. 直接使用 docker-compose.postgres.yml 启动
#    docker compose -f docker-compose.postgres.yml up -d --build
# ============================================

# 应用鉴权密钥。
CHATGPT2API_AUTH_KEY=chatgpt2api

# 对外访问基础 URL。
# CHATGPT2API_BASE_URL=https://your-domain.com

# 存储后端类型。
STORAGE_BACKEND=postgres

# 数据库连接地址。
# SQLite：
# DATABASE_URL=sqlite:////app/data/accounts.db
# PostgreSQL：
DATABASE_URL=postgresql://chatgpt2api:chatgpt2api@postgres:5432/chatgpt2api

# 内置 Postgres 服务配置。
POSTGRES_DB=chatgpt2api
POSTGRES_USER=chatgpt2api
POSTGRES_PASSWORD=chatgpt2api
POSTGRES_PORT=5433

# Git 存储配置。
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git
# GIT_TOKEN=your_git_token_here
GIT_BRANCH=main
GIT_FILE_PATH=accounts.json
GIT_AUTH_KEYS_FILE_PATH=auth_keys.json

# Docker 本地构建目标。
DOCKER_TARGET=app-with-web

# 可选依赖安装开关。
ENABLE_GIT_STORAGE=0
ENABLE_POSTGRES_STORAGE=1

# 国内镜像源设置。
USE_CN_MIRROR=1
APT_MIRROR=https://mirrors.aliyun.com/debian
APT_SECURITY_MIRROR=https://mirrors.aliyun.com/debian-security
PYPI_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.aliyun.com
NPM_REGISTRY=https://registry.npmmirror.com
